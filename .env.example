# OpenAI API key — used for deal summaries, todo generation, and board prep
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Your name — used in AI-generated pass notes and todo prompts
USER_NAME=Alice

# Your firm name — used in AI prompts and meeting title parsing
FIRM_NAME=Acme Capital

# Your firm's email domains (comma-separated) — filters your team out of contact lists
FIRM_DOMAINS=acmecapital.com,acme.vc

# Your firm's team member names (comma-separated, lowercase) — filters colleagues
# out of meeting title parsing. Include first names and full names.
FIRM_PEOPLE=alice,bob,carol,alice smith,bob jones
