{
  "name": "central",
  "version": "0.1.0",
  "author": "Craft Ventures",
  "description": "VC portfolio management and deal flow tracker",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --mac --dir",
    "build:dmg": "vite build && electron-builder --mac dmg",
    "preview": "vite preview",
    "electron:dev": "vite build && electron ."
  },
  "build": {
    "appId": "com.craft.central",
    "productName": "Central",
    "icon": "build/icon.icns",
    "mac": {
      "category": "public.app-category.business",
      "target": "dir",
      "identity": null,
      "icon": "build/icon.icns"
    },
    "files": [
      "dist",
      "dist-electron",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/pdf-parse/**",
      "node_modules/xlsx/**"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "date-fns": "^4.1.0",
    "googleapis": "^144.0.0",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
